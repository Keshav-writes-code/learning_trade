---
import BaseLayout from '@/layouts/Baselayout.astro';
import type { PageMetadata } from '@/types';
import Section1 from '@/components/showcase/section1.astro';
import Section2 from '@/components/showcase/section2.astro';
import Section3 from '@/components/showcase/section3.astro';
import Section4 from '@/components/showcase/section4.astro';
import Section5 from '@/components/showcase/section5.astro';
import Section6 from '@/components/showcase/section6.astro';
import Section7 from '@/components/showcase/section7.astro';
import Section8 from '@/components/showcase/section8.astro';
import Section9 from '@/components/showcase/section9.astro';
import Section10 from '@/components/showcase/section10.astro';
import Section11 from '@/components/showcase/section11.astro';
import Section12 from '@/components/showcase/section12.astro';
import Section13 from '@/components/showcase/section13.astro';

const page_metadata: PageMetadata = {
  title: 'Learning Trade | Hyper-Local Study Resources',
  description:
    'Access highly personalized Previous Year Question Papers (PYQ), study notes, and academic resources tailored to your college, branch, and semester. Share resources and earn followers.',
  open_graph: {
    title: 'Learning Trade - Personalized PYQ & Study Materials',
    type: 'website',
    image: 'page_fallback_opengraph_image.jpg',
  },
} as const;
---

<BaseLayout page_metadata={page_metadata}>
  <main class="min-h-screen bg-[#030303] text-gray-50 font-sans selection:bg-white/30 selection:text-white overflow-x-hidden relative">
    
    <Section1 />
    <Section2 />

    <div class="relative z-10 pt-32 pb-20">
      <Section3 />
      <Section4 />
      <Section5 />
      <Section6 />
      <Section7 />
      <Section8 />
      <Section9 />
      <Section10 />
      <Section11 />
      <Section12 />
      <Section13 />
    </div>
  </main>
</BaseLayout>

<style is:global>
  /* Base overrides */
  body {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    background-color: #030303;
  }

  /* Bulletproof Glassmorphism Classes */
  .glass-panel {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }
  
  .glass-panel-heavy {
    background: rgba(20, 20, 25, 0.4);
    backdrop-filter: blur(40px);
    -webkit-backdrop-filter: blur(40px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: inset 0 0 20px rgba(255,255,255,0.02), 0 20px 40px rgba(0,0,0,0.5);
  }

  /* Animations */
  @keyframes ambient {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(50px, -50px) scale(1.1); }
    66% { transform: translate(-30px, 30px) scale(0.9); }
  }

  @keyframes fade-in-up {
    0% { opacity: 0; transform: translateY(40px) scale(0.98); filter: blur(5px); }
    100% { opacity: 1; transform: translateY(0) scale(1); filter: blur(0); }
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  
  @keyframes shimmer {
    100% { transform: translateX(100%); }
  }
  
  @keyframes gradient-x {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .animate-ambient { animation: ambient 25s ease-in-out infinite alternate; }
  .animate-float { animation: float 4s ease-in-out infinite; }
  .animate-marquee { animation: marquee 30s linear infinite; }
  .animate-shimmer { animation: shimmer 2s infinite; }
  .animate-gradient-x { animation: gradient-x 5s ease infinite; }
  
  .is-revealed {
    animation: fade-in-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  /* Navbar scrolled state */
  .nav-scrolled > div {
    background: rgba(15, 15, 15, 0.8) !important;
    border-color: rgba(255, 255, 255, 0.15) !important;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.8) !important;
  }

  /* Mockup Tab Transitions */
  .mockup-view { transition: opacity 0.4s ease, transform 0.4s ease; }
  .mockup-view.hidden { display: none; }
  .mockup-view.active { display: grid; opacity: 1; transform: translateY(0); position: relative; }

  /* 3D Tilt utility */
  .transform-style-3d {
    transform-style: preserve-3d;
  }
  .translate-z-20 {
    transform: translateZ(20px);
  }

  /* Interactive Hover Words */
  .hover-word:hover {
    color: white;
    text-shadow: 0 0 15px rgba(255,255,255,0.8);
    cursor: default;
  }
</style>

<script>
  // Safe execution on DOM load
  document.addEventListener('DOMContentLoaded', () => {
    
    // 1. Scroll Reveal Logic
    const observer = new IntersectionObserver((entries, obs) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-revealed');
          obs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal-up').forEach(el => observer.observe(el));

    // 2. Navbar Scroll Effect
    const navbar = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 20) {
        navbar?.classList.add('nav-scrolled');
      } else {
        navbar?.classList.remove('nav-scrolled');
      }
    });

    // 3. Bento Box Spotlight
    document.querySelectorAll('.bento-card').forEach(card => {
      // Default position center
      (card as HTMLElement).style.setProperty('--mouse-x', `50%`);
      (card as HTMLElement).style.setProperty('--mouse-y', `50%`);
      
      card.addEventListener('mousemove', (e: Event) => {
        const mouseEvent = e as MouseEvent;
        const rect = card.getBoundingClientRect();
        const x = mouseEvent.clientX - rect.left;
        const y = mouseEvent.clientY - rect.top;
        (card as HTMLElement).style.setProperty('--mouse-x', `${x}px`);
        (card as HTMLElement).style.setProperty('--mouse-y', `${y}px`);
      });
    });

    // 4. Interactive Mockup Feed Logic
    const tabs = document.querySelectorAll('.mockup-tab');
    const views = document.querySelectorAll('.mockup-view');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        // Reset tabs
        tabs.forEach(t => {
          t.classList.remove('bg-white', 'text-black', 'shadow-[0_0_15px_rgba(255,255,255,0.3)]', 'active');
          t.classList.add('glass-panel', 'text-gray-300');
        });
        
        // Activate clicked tab
        tab.classList.remove('glass-panel', 'text-gray-300');
        tab.classList.add('bg-white', 'text-black', 'shadow-[0_0_15px_rgba(255,255,255,0.3)]', 'active');

        // Switch views
        const targetId = `view-${tab.getAttribute('data-target')}`;
        
        views.forEach(view => {
          if (view.id === targetId) {
            view.classList.remove('hidden');
            setTimeout(() => {
              view.classList.add('active');
              view.classList.remove('opacity-0', 'translate-y-4');
            }, 10);
          } else {
            view.classList.remove('active');
            view.classList.add('opacity-0', 'translate-y-4');
            setTimeout(() => {
              if(!view.classList.contains('active')) {
                view.classList.add('hidden');
              }
            }, 400);
          }
        });
      });
    });

    // 5. 3D Tilt Card Gamification
    const tiltCard = document.querySelector('.tilt-card') as HTMLElement;
    if (tiltCard) {
      tiltCard.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = tiltCard.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        const centerX = rect.width / 2;
        const centerY = rect.height / 2;
        // Limit rotation to 10 degrees
        const rotateX = ((y - centerY) / centerY) * -10; 
        const rotateY = ((x - centerX) / centerX) * 10;
        tiltCard.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.02, 1.02, 1.02)`;
      });
      tiltCard.addEventListener('mouseleave', () => {
        tiltCard.style.transform = `perspective(1000px) rotateX(0deg) rotateY(0deg) scale3d(1, 1, 1)`;
      });
    }

    // 6. Number Counter Animation
    const counters = document.querySelectorAll('.counter');
    const counterObserver = new IntersectionObserver((entries, obs) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const target = parseFloat(el.getAttribute('data-target') || '0');
          const duration = 2000;
          const steps = 60;
          const stepTime = Math.abs(Math.floor(duration / steps));
          let current = 0;
          
          const timer = setInterval(() => {
            current += target / steps;
            if (current >= target) {
              el.innerText = target.toString();
              clearInterval(timer);
            } else {
              // Handle decimals for rating
              el.innerText = Number.isInteger(target) ? Math.floor(current).toString() : current.toFixed(1);
            }
          }, stepTime);
          
          obs.unobserve(el);
        }
      });
    }, { threshold: 0.5 });
    counters.forEach(counter => counterObserver.observe(counter));

    // 7. FAQ Accordion Logic
    const faqBtns = document.querySelectorAll('.faq-btn');
    faqBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const content = btn.nextElementSibling as HTMLElement;
        const icon = btn.querySelector('.faq-icon');
        
        // Toggle current
        if (content.classList.contains('hidden')) {
          content.classList.remove('hidden');
          setTimeout(() => content.classList.remove('opacity-0'), 10);
          icon?.classList.add('rotate-180');
        } else {
          content.classList.add('opacity-0');
          icon?.classList.remove('rotate-180');
          setTimeout(() => content.classList.add('hidden'), 300);
        }
      });
    });
  });
</script>
