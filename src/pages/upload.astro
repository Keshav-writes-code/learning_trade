---
import AppLayout from '@/layouts/AppLayout.astro';
import type { PageMetadata } from '@/types';

const page_metadata: PageMetadata = {
  title: 'Upload Resource',
  description: 'Upload your Previous Year Question Papers (PYQ), study notes, and academic resources.',
  open_graph: {
    title: 'Learning Trade - Upload Resource',
    type: 'website',
    image: 'page_fallback_opengraph_image.jpg',
  },
} as const;
---

<AppLayout page_metadata={page_metadata}>
  <header class="navbar bg-base-100 border-b border-base-200 sticky top-0 z-50">
    <div class="navbar-start">
      <button class="btn btn-ghost btn-circle" aria-label="Close">
        <div class="i-tabler:x text-2xl"></div>
      </button>
    </div>
    <div class="navbar-center">
      <h1 class="text-xl font-bold truncate">Upload Resource</h1>
    </div>
    <div class="navbar-end"></div>
  </header>

  <main class="max-w-md mx-auto p-4 space-y-6 pb-24">
    <section>
      <div class="relative group cursor-pointer w-full rounded-box border-2 border-dashed border-base-300 bg-base-200 hover:border-primary transition-colors duration-200 overflow-hidden">
        <input type="file" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10" aria-label="Attach File" />
        <div class="flex flex-col items-center justify-center p-8 text-center space-y-4">
          <div class="w-12 h-12 rounded-full bg-base-300 flex items-center justify-center group-hover:bg-primary/10 transition-colors duration-200">
            <div class="i-tabler:file-upload text-3xl text-base-content/60 group-hover:text-primary transition-colors duration-200"></div>
          </div>
          <div>
            <p class="text-sm font-medium mb-1">Tap to upload PDF, Image, or Markdown</p>
            <p class="text-xs uppercase tracking-wider text-base-content/60">Max 25MB</p>
          </div>
        </div>
      </div>
    </section>

    <section>
      <label class="form-control w-full">
        <div class="label">
          <span class="label-text uppercase tracking-wider font-semibold text-xs text-base-content/70">Title</span>
        </div>
        <input type="text" placeholder="e.g., CS101 Midterm 2023" class="input input-bordered w-full" id="resource-title" />
      </label>
    </section>

    <section>
      <label class="form-control w-full">
        <div class="label">
          <span class="label-text uppercase tracking-wider font-semibold text-xs text-base-content/70">Subject</span>
        </div>
        <select class="select select-bordered w-full" id="resource-subject">
          <option disabled selected>Select a subject...</option>
          <option value="cs">Computer Science</option>
          <option value="math">Mathematics</option>
          <option value="phy">Physics</option>
          <option value="eco">Economics</option>
        </select>
      </label>
    </section>

    <section>
      <div class="label px-0 mb-2">
        <span class="label-text uppercase tracking-wider font-semibold text-xs text-base-content/70">Resource Type</span>
      </div>
      <div class="flex flex-wrap gap-3">
        <input type="radio" name="resource-type" value="pyq" aria-label="PYQ" class="btn" checked />
        <input type="radio" name="resource-type" value="lab" aria-label="Lab File" class="btn" />
        <input type="radio" name="resource-type" value="notes" aria-label="Notes" class="btn" />
        <input type="radio" name="resource-type" value="guide" aria-label="Project Guide" class="btn" />
      </div>
    </section>

    <section class="pt-4">
      <button type="button" class="btn btn-primary w-full rounded-full text-lg">
        Post Resource
      </button>
    </section>
  </main>
</AppLayout>
