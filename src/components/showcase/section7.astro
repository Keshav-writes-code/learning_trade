---
---
<!-- 7. Interactive Experience / Feed Tabs -->
      <section id="experience" class="max-w-6xl mx-auto px-6 py-24">
        <div class="text-center mb-16 reveal-up opacity-0">
          <h2 class="text-4xl md:text-6xl font-bold tracking-tighter mb-6 text-white">Experience the feed.</h2>
          <p class="text-xl text-gray-400 max-w-2xl mx-auto font-light">Click the tabs below to see how seamlessly the content filters.</p>
        </div>

        <div class="mx-auto max-w-4xl relative group reveal-up opacity-0 [animation-delay:200ms]">
          <div class="absolute -inset-1 bg-gradient-to-r from-blue-600/30 via-purple-600/30 to-cyan-600/30 rounded-[3rem] blur-2xl opacity-50 group-hover:opacity-100 transition-opacity duration-1000"></div>
          
          <div class="relative glass-panel-heavy rounded-[2.5rem] shadow-[0_20px_50px_rgba(0,0,0,0.5)] overflow-hidden border border-white/[0.1]">
            <div class="h-14 bg-black/40 border-b border-white/[0.08] flex items-center px-6 backdrop-blur-md">
              <div class="flex gap-2">
                <div class="w-3 h-3 rounded-full bg-[#ff5f56] border border-white/10"></div>
                <div class="w-3 h-3 rounded-full bg-[#ffbd2e] border border-white/10"></div>
                <div class="w-3 h-3 rounded-full bg-[#27c93f] border border-white/10"></div>
              </div>
              <div class="mx-auto flex items-center justify-center bg-white/5 rounded-md px-4 py-1 border border-white/5">
                <div class="i-tabler:lock text-gray-500 text-xs mr-2"></div>
                <span class="text-xs text-gray-300 font-medium">app.learningtrade.com</span>
              </div>
              <div class="w-14"></div>
            </div>

            <div class="p-8 md:p-10 min-h-[380px]">
              <div class="flex gap-3 overflow-x-auto pb-4 scrollbar-hide mb-6 border-b border-white/5" id="mockup-tabs">
                <button class="mockup-tab active px-6 py-2 rounded-full bg-white text-black text-sm font-semibold transition-all duration-300" data-target="all">All Resources</button>
                <button class="mockup-tab px-6 py-2 rounded-full glass-panel hover:bg-white/10 text-gray-300 text-sm font-medium transition-all duration-300" data-target="pyqs">Question Papers</button>
                <button class="mockup-tab px-6 py-2 rounded-full glass-panel hover:bg-white/10 text-gray-300 text-sm font-medium transition-all duration-300" data-target="notes">Lecture Notes</button>
              </div>

              <div class="relative" id="mockup-content">
                <!-- ALL View -->
                <div class="mockup-view active grid gap-4 transition-all duration-400" id="view-all">
                  <div class="p-5 rounded-2xl glass-panel hover:bg-white/10 transition-all cursor-pointer flex gap-5 items-center group/card border border-white/5 hover:border-white/20">
                    <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-blue-500 to-cyan-400 flex items-center justify-center shadow-lg shrink-0">
                      <div class="i-tabler:file-description text-white text-xl"></div>
                    </div>
                    <div class="flex-1">
                      <h4 class="text-lg font-bold text-white group-hover/card:text-blue-300 transition-colors">Data Structures - PYQ 2023</h4>
                      <p class="text-xs text-gray-400 mt-1">Complete solved end-semester examination paper.</p>
                    </div>
                    <div class="hidden sm:flex gap-2">
                      <div class="px-3 py-1.5 rounded-lg bg-white/5 text-gray-300 text-xs flex items-center gap-1 hover:bg-white/10"><div class="i-tabler:arrow-up"></div> 142</div>
                      <div class="px-3 py-1.5 rounded-lg bg-white/5 text-gray-300 text-xs flex items-center gap-1 hover:bg-white/10"><div class="i-tabler:download"></div> 89</div>
                    </div>
                  </div>
                  <div class="p-5 rounded-2xl glass-panel hover:bg-white/10 transition-all cursor-pointer flex gap-5 items-center group/card border border-white/5 hover:border-white/20">
                    <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-fuchsia-500 to-pink-500 flex items-center justify-center shadow-lg shrink-0">
                      <div class="i-tabler:notebook text-white text-xl"></div>
                    </div>
                    <div class="flex-1">
                      <h4 class="text-lg font-bold text-white group-hover/card:text-fuchsia-300 transition-colors">OS - Module 1 & 2</h4>
                      <p class="text-xs text-gray-400 mt-1">Detailed handwritten notes covering processes.</p>
                    </div>
                    <div class="hidden sm:flex gap-2">
                      <div class="px-3 py-1.5 rounded-lg bg-white/5 text-gray-300 text-xs flex items-center gap-1 hover:bg-white/10"><div class="i-tabler:arrow-up"></div> 256</div>
                      <div class="px-3 py-1.5 rounded-lg bg-white/5 text-gray-300 text-xs flex items-center gap-1 hover:bg-white/10"><div class="i-tabler:download"></div> 180</div>
                    </div>
                  </div>
                </div>

                <!-- PYQs View -->
                <div class="mockup-view hidden absolute inset-0 grid gap-4 transition-all duration-400 opacity-0 translate-y-4" id="view-pyqs">
                   <div class="p-5 rounded-2xl glass-panel hover:bg-white/10 transition-all cursor-pointer flex gap-5 items-center border border-white/5 hover:border-white/20">
                    <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-blue-500 to-cyan-400 flex items-center justify-center shadow-lg shrink-0">
                      <div class="i-tabler:file-description text-white text-xl"></div>
                    </div>
                    <div class="flex-1">
                      <h4 class="text-lg font-bold text-white">Data Structures - PYQ 2023</h4>
                      <p class="text-xs text-gray-400 mt-1">Solved paper.</p>
                    </div>
                  </div>
                  <div class="p-5 rounded-2xl glass-panel hover:bg-white/10 transition-all cursor-pointer flex gap-5 items-center border border-white/5 hover:border-white/20">
                    <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-indigo-500 to-blue-500 flex items-center justify-center shadow-lg shrink-0">
                      <div class="i-tabler:file-description text-white text-xl"></div>
                    </div>
                    <div class="flex-1">
                      <h4 class="text-lg font-bold text-white">Algorithms - PYQ 2022</h4>
                      <p class="text-xs text-gray-400 mt-1">Unsolved paper.</p>
                    </div>
                  </div>
                </div>

                <!-- Notes View -->
                <div class="mockup-view hidden absolute inset-0 grid gap-4 transition-all duration-400 opacity-0 translate-y-4" id="view-notes">
                   <div class="p-5 rounded-2xl glass-panel hover:bg-white/10 transition-all cursor-pointer flex gap-5 items-center border border-white/5 hover:border-white/20">
                    <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-fuchsia-500 to-pink-500 flex items-center justify-center shadow-lg shrink-0">
                      <div class="i-tabler:notebook text-white text-xl"></div>
                    </div>
                    <div class="flex-1">
                      <h4 class="text-lg font-bold text-white">OS - Module 1 & 2</h4>
                      <p class="text-xs text-gray-400 mt-1">Handwritten notes.</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
