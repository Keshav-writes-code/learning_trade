---
<!-- 9. Interactive Drag & Drop Upload Zone -->
      <section class="max-w-4xl mx-auto px-6 py-24 text-center reveal-up opacity-0">
        <h2 class="text-3xl md:text-5xl font-bold tracking-tighter mb-4 text-white">Share seamlessly.</h2>
        <p class="text-lg text-gray-400 font-light mb-10">Drag, drop, and help thousands of students instantly.</p>
        
        <div class="upload-zone relative glass-panel-heavy rounded-[2.5rem] border-2 border-dashed border-white/20 p-16 transition-all duration-300 hover:border-blue-400 hover:bg-blue-500/5 group cursor-pointer overflow-hidden">
          <div class="absolute inset-0 bg-blue-500/20 blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="relative z-10 flex flex-col items-center">
            <div class="w-20 h-20 rounded-full glass-panel flex items-center justify-center mb-6 group-hover:-translate-y-2 transition-transform duration-300 bg-white/5 border-white/20">
              <div class="i-tabler:cloud-upload text-4xl text-gray-400 group-hover:text-blue-400 transition-colors"></div>
            </div>
            <h3 class="text-xl font-bold text-white mb-2 group-hover:text-blue-300 transition-colors">Drag & drop your files here</h3>
            <p class="text-sm text-gray-500">Supports PDF, PNG, JPG up to 50MB</p>
            <button class="mt-6 px-6 py-2 rounded-full border border-white/20 text-sm font-medium hover:bg-white hover:text-black transition-colors">Browse Files</button>
          </div>
        </div>
      </section>
