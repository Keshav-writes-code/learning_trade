---
---
<!-- 6. Bento Box Features (Fixed Spotlight) -->
      <section id="features" class="max-w-6xl mx-auto px-6 py-20">
        <div class="text-center mb-16 reveal-up opacity-0">
          <h2 class="text-4xl md:text-5xl font-bold tracking-tighter mb-4 text-white">Everything connects.</h2>
          <p class="text-xl text-gray-400 font-light">A powerful ecosystem designed to elevate your academic life.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 auto-rows-[280px]">
          
          <!-- Bento 1 -->
          <div class="md:col-span-2 md:row-span-2 glass-panel-heavy rounded-[2.5rem] p-10 relative overflow-hidden group cursor-default reveal-up opacity-0 bento-card">
            <div class="spotlight absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none z-0" style="background: radial-gradient(800px circle at var(--mouse-x) var(--mouse-y), rgba(255,255,255,0.08), transparent 40%);"></div>
            
            <div class="relative z-10 h-full flex flex-col justify-between">
              <div class="w-16 h-16 rounded-2xl glass-panel flex items-center justify-center mb-6 shadow-lg border border-white/20 bg-white/5 backdrop-blur-md">
                <div class="i-tabler:scan text-3xl text-white group-hover:scale-110 transition-transform duration-500"></div>
              </div>
              <div class="max-w-md">
                <h3 class="text-3xl font-bold tracking-tight mb-4 text-white">Hyper-Local Filtering</h3>
                <p class="text-lg text-gray-400 font-light">
                  Our algorithm cross-references your exact syllabus. If you're in CSE Semester 4, you only see CSE Semester 4. Zero noise.
                </p>
              </div>
            </div>
            
            <!-- Animated Floaters -->
            <div class="absolute right-10 top-1/2 -translate-y-1/2 flex flex-col gap-4 opacity-40 group-hover:opacity-100 transition-all duration-700 group-hover:translate-x-[-10px] z-10 pointer-events-none">
              <div class="glass-panel px-6 py-3 rounded-xl text-sm font-medium flex items-center gap-2 transform rotate-6 shadow-xl border-white/20"><div class="i-tabler:check text-blue-400"></div> Computer Science</div>
              <div class="glass-panel px-6 py-3 rounded-xl text-sm font-medium flex items-center gap-2 transform -rotate-3 translate-x-4 shadow-xl border-white/20"><div class="i-tabler:check text-blue-400"></div> Semester 4</div>
              <div class="glass-panel px-6 py-3 rounded-xl text-sm font-medium flex items-center gap-2 transform rotate-2 translate-x-2 shadow-xl border-white/20"><div class="i-tabler:check text-blue-400"></div> Algorithms</div>
            </div>
          </div>

          <!-- Bento 2 -->
          <div class="glass-panel-heavy rounded-[2.5rem] p-8 relative overflow-hidden group cursor-default reveal-up opacity-0 [animation-delay:100ms] bento-card">
            <div class="spotlight absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none z-0" style="background: radial-gradient(400px circle at var(--mouse-x) var(--mouse-y), rgba(167,139,250,0.15), transparent 40%);"></div>
            <div class="relative z-10 flex flex-col h-full justify-between">
              <div class="w-14 h-14 rounded-2xl glass-panel flex items-center justify-center border border-white/20 bg-white/5">
                <div class="i-tabler:file-download text-2xl text-purple-300 group-hover:-translate-y-1 transition-transform"></div>
              </div>
              <div>
                <h3 class="text-2xl font-bold tracking-tight mb-2 text-white">Instant PYQs</h3>
                <p class="text-gray-400 font-light text-sm">One-click downloads for years of past examination papers.</p>
              </div>
            </div>
          </div>

          <!-- Bento 3 -->
          <div class="glass-panel-heavy rounded-[2.5rem] p-8 relative overflow-hidden group cursor-default reveal-up opacity-0 [animation-delay:200ms] bento-card">
            <div class="spotlight absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none z-0" style="background: radial-gradient(400px circle at var(--mouse-x) var(--mouse-y), rgba(56,189,248,0.15), transparent 40%);"></div>
            <div class="relative z-10 flex flex-col h-full justify-between">
              <div class="relative w-full h-20 mt-2">
                <div class="absolute w-3/4 h-12 glass-panel rounded-xl left-2 top-0 transform group-hover:-translate-y-3 group-hover:rotate-[-4deg] transition-all duration-500 border border-white/10"></div>
                <div class="absolute w-3/4 h-12 glass-panel rounded-xl left-4 top-3 transform group-hover:translate-x-2 transition-all duration-500 border border-white/20 bg-white/5 flex items-center justify-center text-xs font-bold text-white shadow-xl">Top Notes</div>
              </div>
              <div>
                <h3 class="text-2xl font-bold tracking-tight mb-2 text-white">Curated Notes</h3>
                <p class="text-gray-400 font-light text-sm">Handwritten gems from the best students in your batch.</p>
              </div>
            </div>
          </div>

        </div>
      </section>
