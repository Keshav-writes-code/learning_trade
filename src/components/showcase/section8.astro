---
---
<!-- 8. Gamification / 3D Tilt Card -->
      <section id="community" class="max-w-5xl mx-auto px-6 py-24 flex flex-col md:flex-row items-center gap-16">
        <div class="md:w-1/2 reveal-up opacity-0">
          <h2 class="text-4xl md:text-5xl font-bold tracking-tighter mb-6 text-white">Build your academic legacy.</h2>
          <p class="text-xl text-gray-400 font-light mb-8 leading-relaxed">
            Upload quality notes, help your juniors, and watch your profile grow. Become a verified top contributor in your college.
          </p>
          <ul class="space-y-4 text-gray-300">
            <li class="flex items-center gap-3"><div class="w-6 h-6 rounded-full bg-purple-500/20 flex items-center justify-center"><div class="i-tabler:star text-purple-400 text-xs"></div></div> Earn reputation points</li>
            <li class="flex items-center gap-3"><div class="w-6 h-6 rounded-full bg-blue-500/20 flex items-center justify-center"><div class="i-tabler:users text-blue-400 text-xs"></div></div> Gain followers</li>
            <li class="flex items-center gap-3"><div class="w-6 h-6 rounded-full bg-green-500/20 flex items-center justify-center"><div class="i-tabler:badge text-green-400 text-xs"></div></div> Unlock verified badges</li>
          </ul>
        </div>
        
        <div class="md:w-1/2 flex justify-center w-full reveal-up opacity-0 [animation-delay:200ms]">
          <!-- 3D Tilt Card -->
          <div class="tilt-card relative w-full max-w-sm rounded-[2rem] glass-panel-heavy border border-white/20 p-8 shadow-2xl transition-transform ease-out duration-200 transform-style-3d cursor-default">
            <div class="absolute inset-0 bg-gradient-to-tr from-white/5 to-transparent rounded-[2rem] pointer-events-none"></div>
            <div class="flex flex-col items-center text-center translate-z-20">
              <div class="relative w-24 h-24 mb-4">
                <div class="absolute inset-0 bg-gradient-to-tr from-purple-500 to-blue-500 rounded-full blur-md opacity-50"></div>
                <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=Felix&backgroundColor=b6e3f4" alt="Avatar" class="w-full h-full rounded-full border-2 border-white/20 relative z-10 bg-black/50" />
                <div class="absolute -bottom-2 -right-2 bg-gradient-to-r from-yellow-400 to-orange-500 w-8 h-8 rounded-full border-2 border-[#1a1a1a] flex items-center justify-center z-20 shadow-lg">
                  <div class="i-tabler:check text-white text-sm font-bold"></div>
                </div>
              </div>
              <h3 class="text-2xl font-bold text-white">Alex Chen</h3>
              <p class="text-sm text-gray-400 mb-6">Computer Science '25</p>
              
              <div class="flex gap-6 w-full justify-center border-t border-white/10 pt-6">
                <div>
                  <div class="text-2xl font-bold text-white">4.2k</div>
                  <div class="text-xs text-gray-500 uppercase tracking-wider">Rep</div>
                </div>
                <div class="w-px bg-white/10"></div>
                <div>
                  <div class="text-2xl font-bold text-white">850</div>
                  <div class="text-xs text-gray-500 uppercase tracking-wider">Followers</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
